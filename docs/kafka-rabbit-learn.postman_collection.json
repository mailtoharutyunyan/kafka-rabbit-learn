{
  "info": {
    "name": "kafka-rabbit-learn",
    "description": "All endpoints for Kafka and RabbitMQ learning examples",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "kafka_url", "value": "http://localhost:8081" },
    { "key": "rabbit_url", "value": "http://localhost:8082" },
    { "key": "practical_url", "value": "http://localhost:8083" },
    { "key": "realworld_url", "value": "http://localhost:8084" }
  ],
  "item": [
    {
      "name": "Kafka",
      "item": [
        {
          "name": "1. Basics - Send",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/basics/send?message=hello kafka",
            "description": "Simple string message producer/consumer"
          }
        },
        {
          "name": "2. Partitioning - Send with key",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/partitioning/send?key=user-1&message=order-placed",
            "description": "Same key → same partition → ordering guarantee"
          }
        },
        {
          "name": "3. Consumer Groups - Send batch",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/consumergroups/send?count=10",
            "description": "shared-group splits work, audit-group sees everything"
          }
        },
        {
          "name": "4. Manual Ack - Commit",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/manualack/send?message=commit-me",
            "description": "Message will be ack'd"
          }
        },
        {
          "name": "4. Manual Ack - Skip ack",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/manualack/send?message=skip-ack",
            "description": "Message NOT ack'd - redelivered on restart"
          }
        },
        {
          "name": "5. DLT - Normal message",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/dlt/send?message=normal-ok",
            "description": "Processed successfully"
          }
        },
        {
          "name": "5. DLT - Poison pill",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/dlt/send?message=poison-42",
            "description": "Fails → retries → dead letter topic"
          }
        },
        {
          "name": "6. JSON Serde - Send OrderEvent",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/jsonserde/send?customer=alice&amount=199.99",
            "description": "JSON POJO (OrderEvent) serialization"
          }
        },
        {
          "name": "7. Streams - Send text",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/streams/send?line=kafka streams is awesome kafka",
            "description": "Word count stream processing"
          }
        },
        {
          "name": "8. Transactions - Commit",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/transactions/send?rollback=false",
            "description": "Atomic send of 2 messages (committed)"
          }
        },
        {
          "name": "8. Transactions - Rollback",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/transactions/send?rollback=true",
            "description": "Atomic send aborted - consumer sees nothing"
          }
        },
        {
          "name": "9. Idempotency - Send (first)",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/idempotency/send?id=order-123&payload=create",
            "description": "First delivery - processed"
          }
        },
        {
          "name": "9. Idempotency - Send (duplicate)",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/idempotency/send?id=order-123&payload=retry",
            "description": "Same id - DUPLICATE skipped"
          }
        },
        {
          "name": "10. Retry Backoff - Trigger retries",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/retrybackoff/send?message=fail-then-succeed",
            "description": "Fails 3 times with exponential backoff, then succeeds"
          }
        },
        {
          "name": "11. Observability - Send with correlation",
          "request": {
            "method": "POST",
            "url": "{{kafka_url}}/kafka/observability/send?message=trace me",
            "description": "correlationId in headers + Micrometer counters"
          }
        },
        {
          "name": "11. Observability - Check metrics",
          "request": {
            "method": "GET",
            "url": "{{kafka_url}}/actuator/metrics/learn.kafka.messages.sent",
            "description": "View message send counter"
          }
        }
      ]
    },
    {
      "name": "RabbitMQ",
      "item": [
        {
          "name": "1. Basics - Send",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/basics/send?message=hello rabbit",
            "description": "Simple queue with default exchange"
          }
        },
        {
          "name": "2. Work Queues - Send tasks",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/workqueues/send?count=5",
            "description": "Competing consumers (round-robin)"
          }
        },
        {
          "name": "3. Direct Exchange - Info",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/direct/send?key=info&message=system started",
            "description": "Routes to info queue"
          }
        },
        {
          "name": "3. Direct Exchange - Error",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/direct/send?key=error&message=disk full",
            "description": "Routes to error queue"
          }
        },
        {
          "name": "4. Topic Exchange - order.created",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/topic/send?key=order.created&message=order 42",
            "description": "Matches pattern 'order.*' → orders queue"
          }
        },
        {
          "name": "4. Topic Exchange - user.created",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/topic/send?key=user.created&message=new user",
            "description": "Matches pattern 'user.created' → userCreated queue"
          }
        },
        {
          "name": "4. Topic Exchange - user.deleted (no match)",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/topic/send?key=user.deleted&message=gone",
            "description": "No matching binding - message dropped"
          }
        },
        {
          "name": "5. Fanout Exchange - Broadcast",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/fanout/send?message=breaking news",
            "description": "Both queue A and B receive the message"
          }
        },
        {
          "name": "6. Headers Exchange - PDF report",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/headers/send?format=pdf&type=report&body=annual-report",
            "description": "Matches ALL headers → pdf queue"
          }
        },
        {
          "name": "6. Headers Exchange - PNG image",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/headers/send?format=png&type=photo&body=screenshot",
            "description": "Matches format=png → image queue"
          }
        },
        {
          "name": "7. RPC - Call",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/rpc/call?request=hello world",
            "description": "Synchronous request/reply - returns HELLO WORLD"
          }
        },
        {
          "name": "8. DLQ - Normal",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/dlq/send?message=normal-ok",
            "description": "Processed successfully"
          }
        },
        {
          "name": "8. DLQ - Poison pill",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/dlq/send?message=poison-99",
            "description": "Rejected → routed to dead letter queue"
          }
        },
        {
          "name": "9. Manual Ack - ack",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/manualack/send?message=ack-me",
            "description": "Message acknowledged"
          }
        },
        {
          "name": "9. Manual Ack - nack requeue",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/manualack/send?message=nack-requeue",
            "description": "Nack with requeue - message goes back to queue"
          }
        },
        {
          "name": "9. Manual Ack - reject",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/manualack/send?message=reject",
            "description": "Message rejected and dropped"
          }
        },
        {
          "name": "10. Retry Backoff - Trigger",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/retrybackoff/send?message=fail-then-succeed",
            "description": "Retries with exponential backoff"
          }
        },
        {
          "name": "11. Transactions - Publisher confirm",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/transactions/send?message=confirm-me&toMissingQueue=false",
            "description": "Normal send with publisher confirm ACK"
          }
        },
        {
          "name": "11. Transactions - Missing queue (returned)",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/transactions/send?message=unroutable&toMissingQueue=true",
            "description": "Mandatory message to non-existent queue → RETURNED callback"
          }
        },
        {
          "name": "12. Idempotency - Send (first)",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/idempotency/send?id=order-456&payload=create",
            "description": "First delivery - processed"
          }
        },
        {
          "name": "12. Idempotency - Send (duplicate)",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/idempotency/send?id=order-456&payload=retry",
            "description": "Same id - DUPLICATE skipped"
          }
        },
        {
          "name": "13. Observability - Send",
          "request": {
            "method": "POST",
            "url": "{{rabbit_url}}/rabbit/observability/send?message=trace me",
            "description": "correlationId propagation + Micrometer counters"
          }
        },
        {
          "name": "13. Observability - Check metrics",
          "request": {
            "method": "GET",
            "url": "{{rabbit_url}}/actuator/metrics/learn.rabbit.messages.sent",
            "description": "View message send counter"
          }
        }
      ]
    },
    {
      "name": "Practical",
      "item": [
        {
          "name": "1. Delayed - Send with delay",
          "request": {
            "method": "POST",
            "url": "{{practical_url}}/practical/delayed/send?message=reminder&delayMs=5000",
            "description": "Message delivered after 5 seconds via DLX+TTL"
          }
        },
        {
          "name": "2. Priority - Demo",
          "request": {
            "method": "POST",
            "url": "{{practical_url}}/practical/priority/demo",
            "description": "Sends 5 messages with priorities 1-10, highest consumed first"
          }
        },
        {
          "name": "2. Priority - Custom",
          "request": {
            "method": "POST",
            "url": "{{practical_url}}/practical/priority/send?message=urgent-task&priority=10",
            "description": "Send single message with specific priority"
          }
        },
        {
          "name": "3. Compaction - Demo",
          "request": {
            "method": "POST",
            "url": "{{practical_url}}/practical/compaction/demo",
            "description": "Multiple updates per key + tombstone delete"
          }
        },
        {
          "name": "3. Compaction - Upsert",
          "request": {
            "method": "POST",
            "url": "{{practical_url}}/practical/compaction/upsert?userId=user-42&profile={\"name\":\"Dave\"}",
            "description": "Upsert a user profile (latest value wins after compaction)"
          }
        },
        {
          "name": "3. Compaction - Delete (tombstone)",
          "request": {
            "method": "DELETE",
            "url": "{{practical_url}}/practical/compaction/delete?userId=user-42",
            "description": "Send null value = tombstone, key removed during compaction"
          }
        },
        {
          "name": "4. Batch - Send 100 messages",
          "request": {
            "method": "POST",
            "url": "{{practical_url}}/practical/batch/send?count=100",
            "description": "Consumer receives records in batches of up to 50"
          }
        },
        {
          "name": "5. Outbox - Create Order",
          "request": {
            "method": "POST",
            "url": "{{practical_url}}/practical/outbox/create-order?customer=alice&amount=299.99",
            "description": "Saves to DB + outbox table, poller publishes to Kafka within 2s"
          }
        },
        {
          "name": "6. Multi-Tenant - Demo",
          "request": {
            "method": "POST",
            "url": "{{practical_url}}/practical/multitenant/demo",
            "description": "Events routed to tenant-specific topics/queues + audit queue"
          }
        },
        {
          "name": "6. Multi-Tenant - Kafka",
          "request": {
            "method": "POST",
            "url": "{{practical_url}}/practical/multitenant/kafka?tenantId=tenant-a&event=user-signup",
            "description": "Send to tenant-specific Kafka topic"
          }
        },
        {
          "name": "6. Multi-Tenant - Rabbit",
          "request": {
            "method": "POST",
            "url": "{{practical_url}}/practical/multitenant/rabbit?tenantId=tenant-b&eventType=order.placed&payload=order-999",
            "description": "Send to tenant-specific RabbitMQ queue via routing key"
          }
        }
      ]
    },
    {
      "name": "Real-World",
      "item": [
        {
          "name": "1. WebSocket - Send notification",
          "request": {
            "method": "POST",
            "url": "{{realworld_url}}/realworld/websocket/send?message=New order received!",
            "description": "Kafka → WebSocket push. Open http://localhost:8084/websocket-test.html to see live"
          }
        },
        {
          "name": "2. Saga - Success",
          "request": {
            "method": "POST",
            "url": "{{realworld_url}}/realworld/saga/create-order?amount=50&shouldFail=false",
            "description": "Order → Payment COMPLETED → Order CONFIRMED"
          }
        },
        {
          "name": "2. Saga - Failure + Compensation",
          "request": {
            "method": "POST",
            "url": "{{realworld_url}}/realworld/saga/create-order?amount=999&shouldFail=true",
            "description": "Order → Payment FAILED → Order COMPENSATED (cancelled)"
          }
        },
        {
          "name": "3. Consumer Lag - Info",
          "request": {
            "method": "GET",
            "url": "{{realworld_url}}/realworld/consumer-lag/info",
            "description": "Lag monitored every 5s via AdminClient + Micrometer gauge"
          }
        },
        {
          "name": "3. Consumer Lag - Metrics",
          "request": {
            "method": "GET",
            "url": "{{realworld_url}}/actuator/metrics/kafka.consumer.lag",
            "description": "Current lag value from Micrometer"
          }
        },
        {
          "name": "4. Rate Limit - Burst",
          "request": {
            "method": "POST",
            "url": "{{realworld_url}}/realworld/ratelimit/burst?count=20",
            "description": "20 messages sent instantly, consumer processes max 3/sec"
          }
        },
        {
          "name": "5. Quorum Queue - Send",
          "request": {
            "method": "POST",
            "url": "{{realworld_url}}/realworld/quorum/send?message=reliable-msg",
            "description": "RAFT-replicated queue with delivery-limit=5"
          }
        },
        {
          "name": "5. Quorum Queue - Trigger retries",
          "request": {
            "method": "POST",
            "url": "{{realworld_url}}/realworld/quorum/send?message=fail-test",
            "description": "Fails processing → redelivered up to 5 times"
          }
        },
        {
          "name": "6. Kafka Connect - JDBC Source example",
          "request": {
            "method": "GET",
            "url": "{{realworld_url}}/realworld/kafka-connect/jdbc-source-example",
            "description": "Example connector config: DB → Kafka"
          }
        },
        {
          "name": "6. Kafka Connect - Elasticsearch Sink example",
          "request": {
            "method": "GET",
            "url": "{{realworld_url}}/realworld/kafka-connect/elasticsearch-sink-example",
            "description": "Example connector config: Kafka → Elasticsearch"
          }
        },
        {
          "name": "7. Spring Cloud Stream - Kafka config",
          "request": {
            "method": "GET",
            "url": "{{realworld_url}}/realworld/spring-cloud-stream/kafka-config-example",
            "description": "How to use Spring Cloud Stream with Kafka binder"
          }
        },
        {
          "name": "7. Spring Cloud Stream - Rabbit config",
          "request": {
            "method": "GET",
            "url": "{{realworld_url}}/realworld/spring-cloud-stream/rabbit-config-example",
            "description": "Same code with RabbitMQ binder (just swap dependency)"
          }
        }
      ]
    }
  ]
}
